---
import Layout from '../layouts/Layout.astro';

const wedding = {
    couple: 'Kaleb Dunn and James Keaney',
    date: 'Sunday, September 6th, 2026',
    time: '4:00 PM',
    venue: 'Melwood Arts Center',
    cityState: 'Louisville, Kentucky',
    dressCode: 'Cocktail attire'
};
---

<Layout title="Wedding | Dunn-Keaney">
    <section class="max-w-3xl">
        <p class="eyebrow text-primary">Wedding</p>
        <h1 class="mb-6">{wedding.couple}</h1>
        <p class="mb-10">We are grateful to celebrate with our family and friends.</p>
    </section>

    <section class="wedding-grid">
        <figure class="wedding-image">
            <img src="/images/wedding-portrait.jpg" alt="Kaleb and James with their dog in formalwear." />
        </figure>

        <div class="paper-panel">
            <div class="grid gap-8 sm:grid-cols-2">
                <div>
                    <p class="eyebrow text-primary">Date</p>
                    <p>{wedding.date}</p>
                </div>
                <div>
                    <p class="eyebrow text-primary">Time</p>
                    <p>{wedding.time}</p>
                </div>
                <div>
                    <p class="eyebrow text-primary">Venue</p>
                    <p>{wedding.venue}</p>
                </div>
                <div>
                    <p class="eyebrow text-primary">Location</p>
                    <p>{wedding.cityState}</p>
                </div>
                <div>
                    <p class="eyebrow text-primary">Dress Code</p>
                    <p>{wedding.dressCode}</p>
                </div>
            </div>

            <div class="mt-10 pt-8" style="border-top: 1px solid var(--color-border);">
                <p class="eyebrow text-primary">RSVP</p>
                <p class="mb-5">Please respond using the online form.</p>
                <a href="/rsvp" class="btn btn-accent">Go to RSVP</a>
            </div>
        </div>
    </section>
</Layout>
