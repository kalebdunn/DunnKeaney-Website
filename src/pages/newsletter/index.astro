---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const entries = (await getCollection('newsletter', ({ data }) => !data.draft)).sort(
    (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
---

<Layout title="Newsletter | Dunn-Keaney">
    <section class="max-w-3xl">
        <p class="eyebrow text-primary">Newsletter</p>
        <h1 class="mb-6">Family letters and updates</h1>
        <p class="mb-10">An occasional archive of household news, reflections, and milestones.</p>
    </section>

    <section class="max-w-3xl space-y-4">
        {
            entries.length ? (
                entries.map((entry) => (
                    <article class="paper-panel">
                        <p class="eyebrow text-primary">{entry.data.date.toLocaleDateString('en-US', { dateStyle: 'long' })}</p>
                        <h2 class="mb-3 text-2xl">
                            <a href={`/newsletter/${entry.slug}`} class="no-underline hover:opacity-85">
                                {entry.data.title}
                            </a>
                        </h2>
                        <p>{entry.data.excerpt}</p>
                    </article>
                ))
            ) : (
                <p class="paper-panel">No letters published yet.</p>
            )
        }
    </section>
</Layout>
