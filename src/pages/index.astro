---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Dunn-Keaney">
    <section class="max-w-3xl">
        <p class="eyebrow text-primary">Dunn-Keaney</p>
        <h1 class="mb-8">A personal site for family, writing, and correspondence.</h1>
        <p class="max-w-2xl">
            This is a quiet home on the web for announcements, letters, and selected personal work.
        </p>
    </section>

    <section class="section-gap grid gap-4 sm:grid-cols-2">
        <a href="/wedding" class="paper-panel no-underline hover:opacity-90">
            <p class="eyebrow text-primary">Wedding</p>
            <h2 class="mb-3 text-2xl">Celebration details</h2>
            <p>Schedule, location, and event notes.</p>
        </a>

        <a href="/rsvp" class="paper-panel no-underline hover:opacity-90">
            <p class="eyebrow text-primary">RSVP</p>
            <h2 class="mb-3 text-2xl">Respond online</h2>
            <p>Please submit your response and any dietary notes.</p>
        </a>
    </section>
</Layout>
