---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Dunn-Keaney">
    <section class="home-intro">
        <h1 class="mb-8">Welcome to the digital threshold of the Dunn-Keaney household.</h1>
        <p class="max-w-4xl">
            This site holds announcements, letters, and selected personal work from James and Kaleb, alongside a small amount of professional information and wedding details.
        </p>
    </section>

    <figure class="section-gap home-image">
        <img src="/images/home-portrait-wide.jpg" alt="James and Kaleb together outdoors in the evening." />
    </figure>

    <section class="section-gap home-columns">
        <div class="paper-panel">
            <p class="eyebrow text-primary">Purpose</p>
            <h2 class="mb-4 text-2xl">A small household archive</h2>
            <p class="mb-4">
                This site will hold family letters, personal work, and occasional public notes - it also has information about our upcoming wedding.
            </p>
        </div>

        <aside class="paper-panel">
            <p class="eyebrow text-primary">Current Sections</p>
            <ul class="home-list">
                <li><a href="/newsletter">Newsletter</a> for family letters and updates.</li>
                <li><a href="/wedding">Wedding</a> for celebration details and RSVP.</li>
                <li><a href="/kaleb">Kaleb</a> for information about Kaleb and his thoughts.</li>
                <li><a href="/james">James</a> for information about James and his thoughts.</li>
            </ul>
        </aside>
    </section>
</Layout>
