---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Kaleb | Dunn-Keaney">
    <section class="max-w-3xl">
        <p class="eyebrow text-primary">Kaleb</p>
        <h1 class="mb-6">Personal section</h1>
        <p class="mb-10">A quiet home for resume details, essays, and selected projects.</p>
    </section>

    <section class="max-w-3xl grid gap-4 sm:grid-cols-2">
        <a href="/kaleb/resume" class="paper-panel no-underline hover:opacity-90">
            <p class="eyebrow text-primary">Resume</p>
            <h2 class="mb-2 text-2xl">Professional profile</h2>
            <p>Experience, projects, and technical strengths.</p>
        </a>

        <div class="paper-panel">
            <p class="eyebrow text-primary">Writing</p>
            <h2 class="mb-2 text-2xl">Coming soon</h2>
            <p>Essays and notes will be added here over time.</p>
        </div>
    </section>
</Layout>
