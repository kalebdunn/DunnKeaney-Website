---
import Layout from '../layouts/Layout.astro';
---

<Layout title="RSVP | Dunn-Keaney">
    <section class="max-w-3xl">
        <p class="eyebrow text-primary">RSVP</p>
        <h1 class="mb-6">Wedding Response</h1>
        <p class="mb-10">Step 1: confirm your invitation by name. Step 2: submit one response for your household.</p>
    </section>

    <section class="paper-panel max-w-3xl">
        <form id="lookup-form" class="space-y-6">
            <div>
                <label for="lookup-full-name">Full Name</label>
                <input id="lookup-full-name" name="fullName" type="text" required autocomplete="name" />
                <p class="mt-2 text-sm text-primary/70">Use the name shown on your invitation.</p>
            </div>
            <button type="submit" class="btn">Continue</button>
            <p id="lookup-status" class="text-sm" aria-live="polite"></p>
        </form>

        <form id="rsvp-form" class="hidden mt-10 space-y-6">
            <div class="paper-panel">
                <p class="eyebrow mb-2">Invitation Found</p>
                <p id="matched-household" class="text-sm"></p>
                <p id="max-attendees" class="mt-2 text-sm text-primary/70"></p>
            </div>

            <input type="hidden" id="submit-full-name" name="fullName" />

            <div>
                <label for="attendance">Attendance</label>
                <select id="attendance" name="attendance" required>
                    <option value="">Please select</option>
                    <option value="yes">Joyfully accepts</option>
                    <option value="no">Regretfully declines</option>
                </select>
            </div>

            <div>
                <label for="attending-count">Number Attending</label>
                <input id="attending-count" name="attendingCount" type="number" min="0" max="20" value="0" required />
            </div>

            <div>
                <label for="notes">Notes or Dietary Needs (Optional)</label>
                <textarea id="notes" name="notes" rows="4"></textarea>
            </div>

            <p class="sr-only-field">
                <label for="bot-field">
                    Do not fill this out:
                    <input id="bot-field" name="botField" />
                </label>
            </p>

            <button type="submit" class="btn btn-accent">Submit RSVP</button>
            <p id="submit-status" class="text-sm" aria-live="polite"></p>
        </form>
    </section>
</Layout>

<script>
    const lookupForm = document.querySelector('#lookup-form');
    const lookupNameInput = document.querySelector('#lookup-full-name');
    const lookupStatus = document.querySelector('#lookup-status');
    const rsvpForm = document.querySelector('#rsvp-form');
    const submitNameInput = document.querySelector('#submit-full-name');
    const matchedHousehold = document.querySelector('#matched-household');
    const maxAttendeesText = document.querySelector('#max-attendees');
    const attendanceInput = document.querySelector('#attendance');
    const attendingCountInput = document.querySelector('#attending-count');
    const submitStatus = document.querySelector('#submit-status');

    let maxAttendees = 20;

    lookupForm.addEventListener('submit', async (event) => {
        event.preventDefault();
        lookupStatus.textContent = 'Checking invitation...';
        submitStatus.textContent = '';
        rsvpForm.classList.add('hidden');

        const fullName = String(lookupNameInput.value || '').trim();
        if (!fullName) {
            lookupStatus.textContent = 'Please enter your full name.';
            return;
        }

        try {
            const response = await fetch(`/api/rsvp-lookup?fullName=${encodeURIComponent(fullName)}`);
            const data = await response.json();
            if (!response.ok) throw new Error(data.error || 'Lookup failed');

            if (data.responded) {
                lookupStatus.textContent = 'This household has already submitted an RSVP. Please contact the hosts for changes.';
                return;
            }

            maxAttendees = Number(data.maxAttendees || 1);
            submitNameInput.value = fullName;
            matchedHousehold.textContent = data.primaryContact ? `Household: ${data.primaryContact}` : 'Household verified.';
            maxAttendeesText.textContent = `This invitation allows up to ${maxAttendees} attendee${maxAttendees === 1 ? '' : 's'}.`;
            attendingCountInput.max = String(maxAttendees);
            attendingCountInput.value = String(Math.min(Math.max(1, maxAttendees), 2));

            rsvpForm.classList.remove('hidden');
            lookupStatus.textContent = 'Invitation found. Please complete your RSVP below.';
        } catch (error) {
            lookupStatus.textContent = error.message || 'Lookup failed. Please try again.';
        }
    });

    attendanceInput.addEventListener('change', () => {
        if (attendanceInput.value === 'no') {
            attendingCountInput.value = '0';
        } else if (Number(attendingCountInput.value) < 1) {
            attendingCountInput.value = '1';
        }
    });

    rsvpForm.addEventListener('submit', async (event) => {
        event.preventDefault();
        submitStatus.textContent = 'Submitting RSVP...';

        const formData = new FormData(rsvpForm);
        const attendance = String(formData.get('attendance') || '');
        const attendingCount = Number(formData.get('attendingCount') || 0);

        if (attendance === 'yes' && attendingCount < 1) {
            submitStatus.textContent = 'Please provide at least one attendee for an accepted invitation.';
            return;
        }

        if (attendance === 'yes' && attendingCount > maxAttendees) {
            submitStatus.textContent = `Your invitation allows up to ${maxAttendees} attendee${maxAttendees === 1 ? '' : 's'}.`;
            return;
        }

        const payload = {
            fullName: String(formData.get('fullName') || '').trim(),
            attendance,
            attendingCount,
            notes: String(formData.get('notes') || '').trim(),
            botField: String(formData.get('botField') || '')
        };

        try {
            const response = await fetch('/api/rsvp-submit', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            });
            const data = await response.json();
            if (!response.ok) throw new Error(data.error || 'Submission failed');
            window.location.href = '/rsvp/thanks';
        } catch (error) {
            submitStatus.textContent = error.message || 'Submission failed. Please try again.';
        }
    });
</script>
